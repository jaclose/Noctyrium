# Keep Vercel uploads focused on the deployable web app.
/*
!/api
!/api/**
!/lib
!/lib/**
!/db
!/db/**
!/package.json
!/package-lock.json
!/vercel.json
!/.env.example
!/web
!/web/**

# Heavy/local artifacts inside web.
web/node_modules
web/dist
web/Noctyrium-*.zip
web/Noctyrium.app
web/tsconfig.tsbuildinfo
**/.DS_Store
