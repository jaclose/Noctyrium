{
    "configurations": [
        {
            "name": "Launch Chrome",
            "request": "launch",
            "type": "chrome",
            "url": "http://localhost:8080",
            "webRoot": "${workspaceFolder}"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:Noctyrium}",
            "name": "Debug Noctyrium",
            "target": "Noctyrium",
            "configuration": "debug",
            "preLaunchTask": "swift: Build Debug Noctyrium"
        },
        {
            "type": "swift",
            "request": "launch",
            "args": [],
            "cwd": "${workspaceFolder:Noctyrium}",
            "name": "Release Noctyrium",
            "target": "Noctyrium",
            "configuration": "release",
            "preLaunchTask": "swift: Build Release Noctyrium"
        },
        {
            "name": "Containers: Node.js Launch",
            "type": "docker",
            "request": "launch",
            "preLaunchTask": "docker-run: debug",
            "platform": "node",
            "node": {
                "package": "${workspaceFolder}/web/package.json",
                "localRoot": "${workspaceFolder}/web"
            }
        }
    ]
}