# Optional cloud sync backend.
# Recommended: Vercel Marketplace -> Neon Postgres. Copy the pooled connection string here.
DATABASE_URL=

# AI provider scaffold. Phase 1/2 uses mock only.
AI_PROVIDER=mock
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# App metadata. The frontend currently stores schemaVersion in the app state too.
APP_SCHEMA_VERSION=9

# Optional server behavior.
NOCTYRIUM_AUTO_MIGRATE=true
